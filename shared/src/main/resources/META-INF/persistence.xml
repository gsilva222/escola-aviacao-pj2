<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence" version="3.0">
    <persistence-unit name="escolaAviacaoPU" transaction-type="RESOURCE_LOCAL">
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>
        
        <class>pt.ipvc.estg.entities.Perfil</class>
        
        <properties>
            <!-- Configuração do servidor PostgreSQL -->
            <property name="jakarta.persistence.jdbc.url" value="jdbc:postgresql://doberserver222.cc:2345/escola_aviacao"/>
            <property name="jakarta.persistence.jdbc.user" value="admin_escola"/>
            <property name="jakarta.persistence.jdbc.password" value="admin_password123"/>
            <property name="jakarta.persistence.jdbc.driver" value="org.postgresql.Driver"/>

            <!-- Configurações do Hibernate -->
            <property name="hibernate.hbm2ddl.auto" value="validate"/>
            <property name="hibernate.show_sql" value="true"/>
            <property name="hibernate.format_sql" value="true"/>
            <property name="hibernate.dialect" value="org.hibernate.dialect.PostgreSQLDialect"/>
        </properties>
    </persistence-unit>
</persistence>
