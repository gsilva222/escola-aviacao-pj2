<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence" version="3.0">
    <persistence-unit name="escolaAviacaoPU" transaction-type="RESOURCE_LOCAL">
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>
        
        <properties>
            <!-- A TUA LIGAÇÃO AO SERVIDOR DOCKER -->
            <property name="jakarta.persistence.jdbc.url" value="jdbc:postgresql://doberserver222.cc:2345/escola_aviacao"/>
            <property name="jakarta.persistence.jdbc.user" value="admin_escola"/>
            <property name="jakarta.persistence.jdbc.password" value="admin_password123"/>
            <property name="jakarta.persistence.jdbc.driver" value="org.postgresql.Driver"/>

            <!-- Configurações do Hibernate -->
            <property name="hibernate.hbm2ddl.auto" value="validate"/> <!-- Apenas valida se as tabelas existem -->
            <property name="hibernate.show_sql" value="true"/> <!-- Mostra as queries no terminal -->
        </properties>
    </persistence-unit>
</persistence>
